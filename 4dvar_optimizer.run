#!/bin/bash
#PBS -S /bin/bash
#PBS -N gchp_4dvar
#PBS -l select=1:ncpus=24:mpiprocs=24:model=bro_ele
#PBS -l walltime=72:00:00
#PBS -q long
#PBS -j oe
#PBS -W group_list=s1055
#PBS -m bea
#PBS -M kay.suselj@jpl.nasa.gov

# 4D-Var outer loop for GCHP CO2 surface flux optimization.
#
# Resources are requested ONCE.  Each iteration reuses the 24-core allocation
# via mpiexec — no child qsub calls, no queue-waiting between iterations.
#
# Walltime guide: each iteration ≈ 3 h (1.5 h forward + 1.5 h adjoint).
# 20 iterations ≈ 60 h.  Adjust walltime and MAX_ITER accordingly.
#
# Submit from gchp_4Dvar/:  cd gchp_4Dvar && qsub 4dvar_optimizer.run
# Override defaults without editing this file:
#   qsub -v MAX_ITER=10,SIGMA_B=0.3 4dvar_optimizer.run

set -euo pipefail
cd "$PBS_O_WORKDIR"

# ============================================================
#  Helper: die with a message  (defined early — used in env checks below)
# ============================================================
die() { echo "ERROR: $*" >&2; exit 1; }

# ============================================================
#  Configuration  (edit for your system)
# ============================================================
BASE_DIR="$(pwd)"                        # gchp_4Dvar/  (optimizer + control_files live here)
WORK_DIR="$(cd "${BASE_DIR}/../4dvar_design" && pwd)"  # 4dvar_design/ (runs, state, sigma)
FWD_DIR="${WORK_DIR}/forward_run"
ADJ_DIR="${WORK_DIR}/adjoint"
CTRL_FWD_DIR="${BASE_DIR}/control_files/forward"
CTRL_ADJ_DIR="${BASE_DIR}/control_files/adjoint"
SCRIPT_DIR="${BASE_DIR}"                 # Python scripts are in gchp_4Dvar/

SIGMA_FILE="${WORK_DIR}/sigma_co2.nc4"  # shared; ../sigma_co2.nc4 in HEMCO configs and ExtData.rc
FORCING_DIR="${WORK_DIR}/forcing_files"
STATE_FILE="${WORK_DIR}/4dvar_state.npz" # L-BFGS-B state, persisted between iters
OUTPUT_DIR="${WORK_DIR}/4dvar_output"    # sigma_iter_NNN.npy, J_iter_NNN.txt

# Simulation window (must match runConfig_*.sh settings)
T_START="2019-01-01"
T_END="2019-01-04"
TS_CHEM=1200                             # chemistry timestep [s]

# Optimization
NLAT=${NLAT:-46}
NLON=${NLON:-72}
SIGMA_B=${SIGMA_B:-0.5}
MAX_ITER=${MAX_ITER:-20}
GTOL=${GTOL:-1e-5}
FTOL=${FTOL:-1e-8}

# Set RESTART=true to resume from the existing 4dvar_state.npz.
# Default (false) starts fresh from sigma=1, ignoring any previous state.
#   qsub                        4dvar_optimizer.run   # fresh start
#   qsub -v RESTART=true        4dvar_optimizer.run   # resume previous run
RESTART=${RESTART:-false}

# ============================================================
#  Environment
# ============================================================
GCHP_ENV="${FWD_DIR}/gchp.env"
if [ ! -f "${GCHP_ENV}" ]; then
    echo "ERROR: ${GCHP_ENV} not found"; exit 1
fi
source "${GCHP_ENV}"

if ! command -v mpiexec &>/dev/null; then
    echo "ERROR: mpiexec not found after sourcing ${GCHP_ENV}"; exit 1
fi

# Activate Python environment (conda or venv)
PYTHON_ENV="${PYTHON_ENV:-/nobackup/ksuselj1/envs/gchp_4dvar}"
if [ -f "${PYTHON_ENV}/bin/activate" ]; then
    source "${PYTHON_ENV}/bin/activate"
else
    die "Python env not found: ${PYTHON_ENV}  (set PYTHON_ENV= or create it first)"
fi
export PYTHONPATH="${SCRIPT_DIR}:${PYTHONPATH:-}"
if ! python3 -c "import numpy, pandas, xarray, netCDF4" 2>/dev/null; then
    die "Python env is missing required packages (numpy pandas xarray netCDF4)"
fi
echo "Python env: $(python3 --version)  from ${PYTHON_ENV}"

# Read core count from GCHP.rc (NX * NY)
NCORES=$(awk '/^NX[[:space:]]/ {nx=$2} /^NY[[:space:]]/ {ny=$2} END {print nx*ny}' \
         "${FWD_DIR}/GCHP.rc")
echo "Core count from GCHP.rc: ${NCORES}"

mkdir -p "${FORCING_DIR}" "${OUTPUT_DIR}" "${ADJ_DIR}/Restarts"

# ============================================================
#  Copy control files to run directories (control_files/ is the
#  clean template; run dirs receive a fresh copy every invocation)
# ============================================================
[ -d "${CTRL_FWD_DIR}" ] || die "Forward control files not found: ${CTRL_FWD_DIR}"
[ -d "${CTRL_ADJ_DIR}" ] || die "Adjoint control files not found: ${CTRL_ADJ_DIR}"
rsync -a "${CTRL_FWD_DIR}/" "${FWD_DIR}/"
rsync -a "${CTRL_ADJ_DIR}/" "${ADJ_DIR}/"
echo "Control files synced to run directories"

# ============================================================
#  Patch runConfig timing from T_START / T_END
# ============================================================
START_FMT="$(echo "${T_START}" | tr -d '-') 000000"
END_FMT="$(echo "${T_END}"   | tr -d '-') 000000"
DURATION_DAYS=$(( ($(date -d "${T_END}" +%s) - $(date -d "${T_START}" +%s)) / 86400 ))
DURATION_FMT="$(printf '%08d' "${DURATION_DAYS}") 000000"

for _cfg in "${FWD_DIR}/runConfig_forward.sh" "${ADJ_DIR}/runConfig_adjoint.sh"; do
    sed -i "s/^Start_Time=.*/Start_Time=\"${START_FMT}\"/" "${_cfg}"
    sed -i "s/^End_Time=.*/End_Time=\"${END_FMT}\"/"       "${_cfg}"
    sed -i "s/^Duration=.*/Duration=\"${DURATION_FMT}\"/"  "${_cfg}"
done

# Adjoint always reads its IC from the fixed name written by the forward run
sed -i 's/^INITIAL_RESTART=.*/INITIAL_RESTART=gcchem_initial_restart.nc4/' \
    "${ADJ_DIR}/runConfig_adjoint.sh"

echo "runConfig patched: Start=\"${START_FMT}\"  End=\"${END_FMT}\"  Duration=\"${DURATION_FMT}\""

# ============================================================
#  Restart / fresh-start handling
# ============================================================
if [ "${RESTART}" = "true" ]; then
    if [ -f "${STATE_FILE}" ]; then
        ITER_DONE=$(python3 -c \
            "import numpy as np; s=np.load('${STATE_FILE}'); print(int(s['iteration'])-1)")
        echo "Resuming: ${ITER_DONE} iteration(s) already completed, continuing from $((ITER_DONE+1))"
    else
        echo "WARNING: RESTART=true but no state file found at ${STATE_FILE}. Starting fresh."
    fi
else
    if [ -f "${STATE_FILE}" ]; then
        echo "Fresh start: removing existing state file ${STATE_FILE}"
        rm -f "${STATE_FILE}"
    fi
    echo "Starting fresh from sigma=1"
fi

# ============================================================
#  Outer loop
# ============================================================
echo "========================================================"
echo " 4D-Var start  $(date)"
echo " nlat=${NLAT}  nlon=${NLON}  sigma_b=${SIGMA_B}  max_iter=${MAX_ITER}"
echo "========================================================"

for iter in $(seq 1 "${MAX_ITER}"); do
    echo ""
    echo "-------- Iteration ${iter} / ${MAX_ITER}  $(date) --------"

    # ----------------------------------------------------------
    # (1) Write sigma_co2.nc4  from current state
    # ----------------------------------------------------------
    python3 "${SCRIPT_DIR}/write_sigma.py" \
        --sigma-file "${SIGMA_FILE}" \
        --state-file "${STATE_FILE}" \
        --nlat "${NLAT}" --nlon "${NLON}" \
        --t-start "${T_START}" \
        || die "write_sigma.py failed"

    # ----------------------------------------------------------
    # (2) Forward GCHP
    # ----------------------------------------------------------
    echo "[iter ${iter}] Forward GCHP"
    cd "${FWD_DIR}"

    # Cleanup (mirrors gchp.forward.run)
    rm -f gcadj_internal_checkpoint* gcadj_import_checkpoint*
    [ -d OutputDir ] && rm -f OutputDir/*
    rm -f Restarts/gcchem_internal_checkpoint* cap_restart

    ./runConfig_forward.sh > gchp.log 2>&1 \
        || die "runConfig_forward.sh failed (iter ${iter})"

    mpiexec -n "${NCORES}" ./gchp >> gchp.log 2>&1 \
        || die "Forward GCHP failed (iter ${iter}). See ${FWD_DIR}/gchp.log"

    # ----------------------------------------------------------
    # (3) Observation cost J + forcing files
    # ----------------------------------------------------------
    echo "[iter ${iter}] Computing forcing (J_obs and dJ/dE)"
    SAT_FILE=$(ls "${FWD_DIR}/OutputDir"/GEOSChem.sat_track.*.nc4 2>/dev/null \
               | tail -1)
    [ -z "${SAT_FILE}" ] && die "No sat_track file in ${FWD_DIR}/OutputDir"

    python3 "${SCRIPT_DIR}/co2_adjoint_forcing.py" \
        "${SAT_FILE}" "${FORCING_DIR}" \
        --ts-chem "${TS_CHEM}" \
        --t-start "${T_START}T00:00:00" \
        --t-end   "${T_END}T23:59:59" \
        || die "co2_adjoint_forcing.py failed (iter ${iter})"

    # ----------------------------------------------------------
    # (4) Copy forward checkpoints to adjoint directory
    # ----------------------------------------------------------
    echo "[iter ${iter}] Moving checkpoints"
    cd "${FWD_DIR}"
    for f in gcadj_internal_checkpoint* gcadj_import_checkpoint*; do
        [ -f "${f}" ] && mv "${f}" "${ADJ_DIR}/" \
            && echo "  Moved ${f}"
    done

    # Forward restart → adjoint initial condition (fixed name expected by runConfig)
    _ckpt=$(ls Restarts/gcchem_internal_checkpoint* 2>/dev/null | head -1)
    [ -z "${_ckpt}" ] && die "No gcchem_internal_checkpoint in ${FWD_DIR}/Restarts"
    mv "${_ckpt}" "${ADJ_DIR}/gcchem_initial_restart.nc4" \
        && echo "  Moved $(basename "${_ckpt}") → gcchem_initial_restart.nc4"

    # ----------------------------------------------------------
    # (5) Adjoint GCHP
    # ----------------------------------------------------------
    echo "[iter ${iter}] Adjoint GCHP"
    cd "${ADJ_DIR}"

    # Cleanup (mirrors gchp.adjoint.run)
    [ -d OutputDir ] && rm -f OutputDir/GEOSChem*
    rm -f Restarts/gcchem_internal_checkpoint* cap_restart

    ./runConfig_adjoint.sh > gchp.log 2>&1 \
        || die "runConfig_adjoint.sh failed (iter ${iter})"

    mpiexec -n "${NCORES}" ./gchp >> gchp.log 2>&1 \
        || die "Adjoint GCHP failed (iter ${iter}). See ${ADJ_DIR}/gchp.log"

    # ----------------------------------------------------------
    # (6) L-BFGS-B step: update sigma, check convergence
    # ----------------------------------------------------------
    echo "[iter ${iter}] L-BFGS-B optimizer step"
    cd "${BASE_DIR}"

    rc=0
    python3 "${SCRIPT_DIR}/lbfgsb_step.py" \
        --state-file  "${STATE_FILE}" \
        --forcing-dir "${FORCING_DIR}" \
        --adj-output  "${ADJ_DIR}/OutputDir" \
        --nlat "${NLAT}" --nlon "${NLON}" \
        --sigma-b "${SIGMA_B}" \
        --t-start "${T_START}" \
        --gtol "${GTOL}" --ftol "${FTOL}" \
        || rc=$?

    # Save sigma snapshot for diagnostics
    cp "${STATE_FILE}" "${OUTPUT_DIR}/4dvar_state_iter$(printf '%03d' "${iter}").npz"

    if [ "${rc}" -eq 1 ]; then
        echo "========================================================"
        echo " CONVERGED at iteration ${iter}  $(date)"
        echo "========================================================"
        break
    elif [ "${rc}" -ne 0 ]; then
        die "lbfgsb_step.py returned error code ${rc}"
    fi

done

echo ""
echo "========================================================"
echo " 4D-Var finished  $(date)"
echo " Final state: ${STATE_FILE}"
echo " Per-iteration snapshots: ${OUTPUT_DIR}/"
echo "========================================================"
